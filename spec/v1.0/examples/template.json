{
  "$schema": "https://aredegalli.it/super-webflow/v1.0/template.schema.json",
  "version": "1.0",
  "id": "minimal-example",
  "name": "Minimal Template",
  "category": "generic",

  "theme": {
    "id": "minimal-dark",
    "name": "Minimal Dark",
    "version": "1.0.0",
    "colors": {
      "primary":        "#6C5CE7",
      "primaryLight":   "#A29BFE",
      "primaryDark":    "#4834D4",
      "secondary":      "#00B894",
      "secondaryLight": "#55EFC4",
      "secondaryDark":  "#00876E",
      "accent":         "#FD79A8",
      "accentLight":    "#FDCFE2",
      "background":     "#0A0A0F",
      "backgroundAlt":  "#13131A",
      "surface":        "#1A1A26",
      "surfaceAlt":     "#252535",
      "overlay":        "rgba(0,0,0,0.65)",
      "text":           "#FFFFFF",
      "textSecondary":  "#A0A0B0",
      "textMuted":      "#6B6B80",
      "textInverse":    "#0A0A0F",
      "textOnPrimary":  "#FFFFFF",
      "border":         "#2A2A3A",
      "borderStrong":   "#3D3D55",
      "borderFocus":    "#6C5CE7",
      "success":        "#00B894",
      "successLight":   "#DCFFF6",
      "warning":        "#FDCB6E",
      "warningLight":   "#FFF8E7",
      "danger":         "#D63031",
      "dangerLight":    "#FFE8E8",
      "info":           "#0984E3",
      "infoLight":      "#E3F2FF"
    },
    "typography": {
      "fonts": {
        "heading": "Poppins",
        "body":    "Inter",
        "mono":    "JetBrains Mono"
      },
      "availableWeights": [400, 500, 600, 700],
      "scale": {
        "xs":   12,
        "sm":   14,
        "base": 16,
        "lg":   18,
        "xl":   20,
        "2xl":  24,
        "3xl":  30,
        "4xl":  36,
        "5xl":  48,
        "6xl":  60,
        "7xl":  72
      },
      "lineHeights": {
        "xs":   1.5,
        "sm":   1.5,
        "base": 1.6,
        "lg":   1.5,
        "xl":   1.4,
        "2xl":  1.3,
        "3xl":  1.2,
        "4xl":  1.1,
        "5xl":  1.05,
        "6xl":  1.0,
        "7xl":  1.0
      }
    },
    "spacing": {
      "base": 4,
      "scale": {
        "0": 0, "1": 4, "2": 8, "3": 12, "4": 16,
        "5": 20, "6": 24, "8": 32, "10": 40, "12": 48,
        "16": 64, "20": 80, "24": 96
      }
    },
    "radii": {
      "none": 0, "xs": 2, "sm": 4, "md": 8,
      "lg": 12, "xl": 16, "2xl": 24, "3xl": 32, "full": 9999
    },
    "shadows": {
      "none": null,
      "sm":   { "offsetX": 0, "offsetY": 1, "blur": 3,  "spread": 0,  "color": "rgba(0,0,0,0.25)" },
      "md":   { "offsetX": 0, "offsetY": 4, "blur": 12, "spread": 0,  "color": "rgba(0,0,0,0.35)" },
      "lg":   { "offsetX": 0, "offsetY": 8, "blur": 24, "spread": -2, "color": "rgba(0,0,0,0.4)"  },
      "xl":   { "offsetX": 0, "offsetY": 16,"blur": 48, "spread": -4, "color": "rgba(0,0,0,0.5)"  },
      "inner":{ "offsetX": 0, "offsetY": 2, "blur": 4,  "spread": 0,  "color": "rgba(0,0,0,0.3)", "inset": true }
    },
    "transitions": {
      "fast":   120,
      "normal": 250,
      "slow":   400,
      "easing": {
        "default": "ease",
        "in":      "ease-in",
        "out":     "ease-out",
        "inOut":   "ease-in-out",
        "spring":  "cubic-bezier(0.34,1.56,0.64,1)"
      }
    },
    "zIndex": {
      "base":    0,
      "raised":  10,
      "sticky":  50,
      "overlay": 100,
      "modal":   200,
      "popup":   300,
      "tooltip": 400,
      "max":     9999
    }
  },

  "meta": {
    "title": "{{coach.fullName}} â€” Personal Trainer",
    "description": "Scopri i programmi di allenamento personalizzati."
  },

  "dataSchema": {
    "coach.fullName": {
      "type": "string",
      "required": true,
      "label": "Nome completo",
      "order": 1,
      "group": "Profilo"
    },
    "coach.tagline": {
      "type": "string",
      "required": true,
      "label": "Tagline",
      "hint": "Una frase che ti rappresenta. Max 100 caratteri.",
      "validation": { "maxLength": 100 },
      "order": 2,
      "group": "Profilo"
    },
    "coach.avatar": {
      "type": "image",
      "required": true,
      "label": "Foto profilo",
      "order": 3,
      "group": "Profilo"
    }
  },

  "pages": {
    "home": {
      "id": "home-root",
      "type": "container",
      "style": { "backgroundColor": "background", "minHeight": "100vh" },
      "layout": { "direction": "column" },
      "children": [
        {
          "id": "hero-section",
          "type": "section",
          "style": {
            "padding": [80, 40],
            "backgroundOverlay": "rgba(10,10,15,0.6)"
          },
          "layout": { "direction": "column", "alignItems": "center", "gap": 24 },
          "children": [
            {
              "id": "coach-avatar",
              "type": "avatar",
              "props": { "size": 120, "shape": "circle" },
              "data": { "bindAttributes": { "src": "coach.avatar" }, "fallback": "/placeholder.jpg" }
            },
            {
              "id": "coach-name",
              "type": "heading",
              "props": { "level": 1 },
              "style": {
                "fontSize": "4xl",
                "fontFamily": "heading",
                "color": "text",
                "textAlign": "center"
              },
              "data": { "field": "coach.fullName" },
              "responsive": {
                "sm": { "fontSize": "3xl" }
              }
            },
            {
              "id": "coach-tagline",
              "type": "paragraph",
              "style": {
                "fontSize": "xl",
                "color": "textSecondary",
                "textAlign": "center",
                "maxWidth": 560
              },
              "data": { "field": "coach.tagline" }
            },
            {
              "id": "cta-button",
              "type": "button",
              "props": {
                "label": "Contattami",
                "variant": "primary",
                "size": "lg"
              },
              "interactions": [
                {
                  "trigger": "click",
                  "action": { "type": "scroll-to", "nodeId": "contact-section", "behavior": "smooth" }
                }
              ]
            }
          ]
        },
        {
          "id": "contact-section",
          "type": "section",
          "style": {
            "padding": [80, 40],
            "backgroundColor": "surface"
          },
          "layout": { "direction": "column", "alignItems": "center", "gap": 32 },
          "children": [
            {
              "id": "contact-title",
              "type": "heading",
              "props": { "level": 2, "text": "Scrivimi" },
              "style": { "fontSize": "3xl", "fontFamily": "heading", "color": "text" }
            },
            {
              "id": "contact-form-node",
              "type": "contact-form",
              "props": {
                "fields": [
                  { "type": "text",  "name": "name",    "label": "Il tuo nome",  "required": true  },
                  { "type": "email", "name": "email",   "label": "Email",        "required": true  },
                  { "type": "textarea", "name": "message", "label": "Messaggio", "required": true  }
                ],
                "submitLabel": "Invia messaggio",
                "endpoint": "/api/contact",
                "successMessage": "Messaggio inviato! Ti rispondo entro 24 ore."
              },
              "style": { "width": "100%", "maxWidth": 560 }
            }
          ]
        }
      ]
    }
  }
}

