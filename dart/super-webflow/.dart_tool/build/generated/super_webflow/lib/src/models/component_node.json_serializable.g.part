          ? null
          : StyleProps.fromJson(json['style'] as Map<String, dynamic>),
      layout: json['layout'] == null
          ? null
          : LayoutProps.fromJson(json['layout'] as Map<String, dynamic>),
      responsive: (json['responsive'] as Map<String, dynamic>?)?.map(
        (k, e) => MapEntry(k, e as Map<String, dynamic>),
      ),
      data: json['data'] == null
          ? null
          : DataBinding.fromJson(json['data'] as Map<String, dynamic>),
      condition: json['condition'] == null
          ? null
          : DataCondition.fromJson(json['condition'] as Map<String, dynamic>),
      interactions: (json['interactions'] as List<dynamic>?)
          ?.map((e) => Interaction.fromJson(e as Map<String, dynamic>))
          .toList(),
      role: json['role'] as String?,
      ariaLabel: json['ariaLabel'] as String?,
      ariaLive: json['ariaLive'] as String?,
      tabIndex: (json['tabIndex'] as num?)?.toInt(),
      builder: json['_builder'] == null
          ? null
          : BuilderMeta.fromJson(json['_builder'] as Map<String, dynamic>),
    );

Map<String, dynamic> _$$ComponentNodeImplToJson(_$ComponentNodeImpl instance) =>
    <String, dynamic>{
      'id': instance.id,
      'type': _$ComponentTypeEnumMap[instance.type]!,
      'name': instance.name,
      'locked': instance.locked,
      'children': instance.children,
      'props': instance.props,
      'style': instance.style,
      'layout': instance.layout,
      'responsive': instance.responsive,
      'data': instance.data,
      'condition': instance.condition,
      'interactions': instance.interactions,
      'role': instance.role,
      'ariaLabel': instance.ariaLabel,
      'ariaLive': instance.ariaLive,
      'tabIndex': instance.tabIndex,
