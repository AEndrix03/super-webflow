_$BuilderMetaImpl _$$BuilderMetaImplFromJson(Map<String, dynamic> json) =>
    _$BuilderMetaImpl(
      editable: json['editable'] as bool?,
      resizable: json['resizable'] as bool?,
      movable: json['movable'] as bool?,
      deletable: json['deletable'] as bool?,
      group: json['group'] as String?,
      icon: json['icon'] as String?,
      description: json['description'] as String?,
      previewData: json['previewData'] as Map<String, dynamic>?,
    );

Map<String, dynamic> _$$BuilderMetaImplToJson(_$BuilderMetaImpl instance) =>
    <String, dynamic>{
      'editable': instance.editable,
      'resizable': instance.resizable,
      'movable': instance.movable,
      'deletable': instance.deletable,
      'group': instance.group,
      'icon': instance.icon,
      'description': instance.description,
      'previewData': instance.previewData,
    };

_$ComponentNodeImpl _$$ComponentNodeImplFromJson(Map<String, dynamic> json) =>
    _$ComponentNodeImpl(
      id: json['id'] as String,
      type: $enumDecode(_$ComponentTypeEnumMap, json['type']),
